-- 7. Створення індексів для оптимізації запитів
CREATE INDEX IF NOT EXISTS idx_profiles_email ON profiles(email);
CREATE INDEX IF NOT EXISTS idx_profiles_role ON profiles(role);
CREATE INDEX IF NOT EXISTS idx_profiles_status ON profiles(status);
CREATE INDEX IF NOT EXISTS idx_parser_logs_timestamp ON parser_logs(timestamp DESC);
CREATE INDEX IF NOT EXISTS idx_parser_logs_level ON parser_logs(level);
CREATE INDEX IF NOT EXISTS idx_daily_stats_date ON daily_stats(date DESC);
CREATE INDEX IF NOT EXISTS idx_hourly_load_date_hour ON hourly_load(date DESC, hour DESC);

-- 8. Налаштування Row Level Security (RLS)
ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;
ALTER TABLE parser_logs ENABLE ROW LEVEL SECURITY;
ALTER TABLE daily_stats ENABLE ROW LEVEL SECURITY;
ALTER TABLE hourly_load ENABLE ROW LEVEL SECURITY;

-- Політика для адміністраторів (повний доступ)
CREATE POLICY "Admins have full access to profiles" ON profiles
  FOR ALL USING (
    auth.jwt() ->> 'role' = 'admin'
  );

CREATE POLICY "Admins have full access to parser_logs" ON parser_logs
  FOR ALL USING (
    auth.jwt() ->> 'role' = 'admin'
  );

CREATE POLICY "Admins have full access to daily_stats" ON daily_stats
  FOR ALL USING (
    auth.jwt() ->> 'role' = 'admin'
  );

CREATE POLICY "Admins have full access to hourly_load" ON hourly_load
  FOR ALL USING (
    auth.jwt() ->> 'role' = 'admin'
  );

-- Політика для звичайних користувачів (тільки читання своїх даних)
CREATE POLICY "Users can view their own profile" ON profiles
  FOR SELECT USING (
    auth.uid() = id
  );

-- 9. Перевірка результатів
SELECT 'Profiles count:' as info, COUNT(*) as count FROM profiles
UNION ALL
SELECT 'Parser logs count:', COUNT(*) FROM parser_logs
UNION ALL
SELECT 'Daily stats count:', COUNT(*) FROM daily_stats
UNION ALL
SELECT 'Hourly load count:', COUNT(*) FROM hourly_load;

-- Готово! Тестові дані успішно додано.
