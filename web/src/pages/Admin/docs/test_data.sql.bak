-- Тестові дані для адмін-панелі SvitloSk
-- Виконайте цей скрипт у Supabase SQL Editor після створення таблиць

-- 1. Створення таблиць (якщо ще не створені)
CREATE TABLE IF NOT EXISTS profiles (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  email TEXT,
  role TEXT DEFAULT 'user',
  status TEXT DEFAULT 'active',
  last_login TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS parser_logs (
  id BIGSERIAL PRIMARY KEY,
  timestamp TIMESTAMP DEFAULT NOW(),
  level TEXT,
  message TEXT,
  source TEXT,
  device_id UUID
);

CREATE TABLE IF NOT EXISTS daily_stats (
  date DATE PRIMARY KEY,
  processed_records INT DEFAULT 0,
  errors INT DEFAULT 0,
  avg_latency_ms FLOAT DEFAULT 0
);

CREATE TABLE IF NOT EXISTS hourly_load (
  date DATE,
  hour INT,
  requests INT DEFAULT 0,
  avg_response_ms FLOAT DEFAULT 0,
  PRIMARY KEY (date, hour)
);

-- 2. Очищення існуючих тестових даних (опціонально)
-- TRUNCATE TABLE profiles, parser_logs, daily_stats, hourly_load CASCADE;

